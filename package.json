{
  "name": "codex-usage-monitor",
  "version": "0.1.0",
  "description": "Local web dashboard for monitoring Codex token consumption on this machine (for shared-account / 拼车 quota monitoring). Reads ~/.codex/sessions/**/*.jsonl.",
  "type": "module",
  "bin": {
    "codex-usage-monitor": "src/server.mjs"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "report": "node src/cli.mjs",
    "package": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-package.ps1",
    "package:export": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-export-package.ps1",
    "build:exe": "node scripts/build-sea.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "png-to-ico": "^3.0.1",
    "postject": "^1.0.0-alpha.6",
    "rcedit": "^5.0.2"
  }
}
